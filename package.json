  "repository": {
    "type": "git",
    "url": "https://github.com/dlepi24/tandoor-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/dlepi24/tandoor-mcp/issues"
  },
  "homepage": "https://github.com/dlepi24/tandoor-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }

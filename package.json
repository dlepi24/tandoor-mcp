{
  "name": "tandoor-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Tandoor recipe and meal plan management",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "tandoor-mcp": "./build/index.js"
  },
